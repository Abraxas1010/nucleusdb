[Unit]
Description=NucleusDB Discord Immutable Record Bot
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=nucleusdb
Group=nucleusdb
EnvironmentFile=/etc/nucleusdb/discord.env
ExecStart=/usr/local/bin/nucleusdb-discord
Restart=always
RestartSec=5s
NoNewPrivileges=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/var/lib/nucleusdb /etc/nucleusdb
PrivateTmp=true
MemoryMax=512M
CPUQuota=50%

[Install]
WantedBy=multi-user.target
